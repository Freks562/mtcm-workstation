# MTCM Portal - Environment Variables
# Copy to .env and fill in values

# ============================================
# REQUIRED
# ============================================

# Session secret - generate with: openssl rand -hex 32
SESSION_SECRET=your-secret-key-here-change-in-production

# Set to 1 in production for secure cookies
SESSION_SECURE=0

# Comma-separated list of allowed admin emails
ALLOWED_EMAILS=motop1972@gmail.com,freks562@gmail.com

# Owner emails for lead/contact notifications (defaults to ALLOWED_EMAILS)
OWNER_EMAILS=

# ============================================
# GOOGLE OAUTH (required for /signin)
# ============================================

# Get these from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must match exactly what's configured in Google Console
# Local: http://localhost:3000/auth/google/callback
# Production: https://your-domain.com/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ============================================
# WEATHER (required for /weather)
# ============================================

# OpenWeatherMap API key
# Get one at: https://openweathermap.org/api
OWM_API_KEY=

# Default city for weather lookups
WEATHER_DEFAULT_CITY=Washington DC

# Units: metric (°C) or imperial (°F)
WEATHER_DEFAULT_UNITS=metric

# Precipitation alert threshold in mm
WEATHER_ALERT_PRECIP_MM=10

# ============================================
# OPTIONAL - REDIS
# ============================================

# Redis URL for rate limiting and session storage
# Format: redis://user:pass@host:6379/0
REDIS_URL=

# ============================================
# OPTIONAL - SMTP (for email notifications)
# ============================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false

# ============================================
# OPTIONAL - FORM PROTECTION
# ============================================

# IP addresses to bypass rate limiting (comma-separated)
ALLOWLIST_IPS=

# Email domains to bypass rate limiting (comma-separated)
ALLOWLIST_EMAIL_DOMAINS=

# ============================================
# OPTIONAL - AI FEATURES (reserved)
# ============================================

OPENAI_API_KEY=

# ============================================
# OPTIONAL - RECAPTCHA
# ============================================

RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
