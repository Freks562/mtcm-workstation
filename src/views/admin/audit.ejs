<%- include('../layout', { body: `
  <div class="container">
    <div class="page-header">
      <h1>Audit Logs</h1>
      <a href="/admin" class="btn btn-outline">← Back to Admin</a>
    </div>
    
    <div class="filters">
      <form method="GET" class="filter-form">
        <select name="action" class="input">
          <option value="">All Actions</option>
          <option value="LOGIN" ${filters.action === 'LOGIN' ? 'selected' : ''}>Login</option>
          <option value="LOGOUT" ${filters.action === 'LOGOUT' ? 'selected' : ''}>Logout</option>
          <option value="CONTACT_SUBMIT" ${filters.action === 'CONTACT_SUBMIT' ? 'selected' : ''}>Contact Submit</option>
          <option value="LEAD_SUBMIT" ${filters.action === 'LEAD_SUBMIT' ? 'selected' : ''}>Lead Submit</option>
          <option value="CONTENT_PUBLISH" ${filters.action === 'CONTENT_PUBLISH' ? 'selected' : ''}>Content Publish</option>
        </select>
        <button type="submit" class="btn btn-primary">Filter</button>
      </form>
    </div>
    
    <div class="audit-table-wrapper">
      <table class="audit-table">
        <thead>
          <tr>
            <th>Timestamp</th>
            <th>Action</th>
            <th>User</th>
            <th>Details</th>
            <th>IP</th>
          </tr>
        </thead>
        <tbody>
          ${logs.length > 0 ? logs.map(log => '<tr><td>' + new Date(log.timestamp).toLocaleString() + '</td><td><span class="badge badge-' + log.action.toLowerCase() + '">' + log.action + '</span></td><td>' + log.userEmail + '</td><td>' + log.details + '</td><td>' + log.ip + '</td></tr>').join('') : '<tr><td colspan="5" class="no-data">No audit logs found</td></tr>'}
        </tbody>
      </table>
    </div>
    
    <div class="pagination">
      ${pagination.hasPrev ? '<a href="?page=' + (pagination.page - 1) + (filters.action ? '&action=' + filters.action : '') + '" class="btn btn-outline">← Previous</a>' : ''}
      <span class="pagination-info">Page ${pagination.page} of ${pagination.totalPages} (${pagination.total} total)</span>
      ${pagination.hasNext ? '<a href="?page=' + (pagination.page + 1) + (filters.action ? '&action=' + filters.action : '') + '" class="btn btn-outline">Next →</a>' : ''}
    </div>
  </div>
`}) %>
