<%- include('../layout', { body: `
  <div class="container">
    <div class="page-header">
      <h1>User Management</h1>
      <a href="/admin" class="btn btn-outline">← Back to Admin</a>
    </div>
    
    <div class="users-table-wrapper">
      <table class="users-table">
        <thead>
          <tr>
            <th>User</th>
            <th>Email</th>
            <th>Role</th>
            <th>Created</th>
            <th>Last Login</th>
          </tr>
        </thead>
        <tbody>
          ${users.length > 0 ? users.map(u => '<tr><td><div class="user-cell">' + (u.photo ? '<img src="' + u.photo + '" class="user-avatar-sm">' : '') + '<span>' + u.displayName + '</span></div></td><td>' + u.email + '</td><td>' + (u.isOwner ? '<span class="badge badge-owner">Owner</span>' : u.isAdmin ? '<span class="badge badge-admin">Admin</span>' : '<span class="badge badge-user">User</span>') + '</td><td>' + new Date(u.createdAt).toLocaleDateString() + '</td><td>' + new Date(u.lastLogin).toLocaleString() + '</td></tr>').join('') : '<tr><td colspan="5" class="no-data">No users found</td></tr>'}
        </tbody>
      </table>
    </div>
  </div>
`}) %>
