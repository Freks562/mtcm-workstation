<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - MTCM Portal</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header class="header">
    <nav class="nav">
      <a href="/" class="nav-brand">MTCM Portal</a>
      <div class="nav-links">
        <a href="/lead">Lead Form</a>
        <a href="/contact">Contact Us</a>
      </div>
    </nav>
  </header>
  
  <main class="main">
    <div class="container">
      <div class="success-message">
        <div class="success-icon">✓</div>
        <h1><%= title %></h1>
        <p><%= message %></p>
        <div class="success-actions">
          <a href="/" class="btn btn-secondary">Back to Home</a>
        </div>
      </div>
    </div>
  </main>
  
  <footer class="footer">
    <p>&copy; <%= new Date().getFullYear() %> MTCM Portal. All rights reserved.</p>
  </footer>
</body>
</html>
