<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Dashboard - MTCM Portal">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <%- include('../partials/header') %>
  
  <main class="main-content">
    <div class="container">
      <div class="dashboard-header">
        <h1>Dashboard</h1>
        <p>Welcome back, <%= user.displayName %></p>
      </div>
      
      <div class="dashboard-grid">
        <div class="dashboard-card">
          <h3>Weather</h3>
          <p>Check weather forecasts with geolocation and bookmarks</p>
          <a href="/weather" class="btn btn-primary">View Weather</a>
        </div>
        
        <div class="dashboard-card">
          <h3>Federal Capabilities</h3>
          <p>Explore our federal contract vehicles and certifications</p>
          <a href="/federal" class="btn btn-primary">View Capabilities</a>
        </div>
        
        <div class="dashboard-card">
          <h3>Profile</h3>
          <p>Manage your account settings and preferences</p>
          <a href="/dashboard/profile" class="btn btn-outline">View Profile</a>
        </div>
        
        <% if (user.isAdmin) { %>
          <div class="dashboard-card dashboard-card-admin">
            <h3>Admin Panel</h3>
            <p>Access administrative functions and audit logs</p>
            <a href="/admin" class="btn btn-primary">Open Admin</a>
          </div>
        <% } %>
      </div>
    </div>
  </main>
  
  <%- include('../partials/footer') %>
  
  <script src="/js/main.js"></script>
</body>
</html>
