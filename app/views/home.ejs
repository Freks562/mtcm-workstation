<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | MTCM Portal</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-brand">
      <a href="/"><%= config.siteName || 'MTCM Portal' %></a>
    </div>
    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/federal">Federal</a>
      <a href="/lead">Request Info</a>
      <a href="/contact">Contact</a>
      <a href="/weather">Weather</a>
      <% if (user) { %>
        <a href="/admin">Admin</a>
        <a href="/signout">Sign Out</a>
      <% } else { %>
        <a href="/signin">Sign In</a>
      <% } %>
    </div>
  </nav>

  <main class="container">
    <section class="hero">
      <h1>Welcome to MTCM Portal</h1>
      <p class="lead">Your comprehensive portal for federal resources, weather information, and more.</p>
    </section>

    <section class="features">
      <div class="feature-card">
        <h3>🏛️ Federal Resources</h3>
        <p>Access federal kits and downloadable resources.</p>
        <a href="/federal" class="btn">Explore Resources</a>
      </div>
      
      <div class="feature-card">
        <h3>🌤️ Weather Dashboard</h3>
        <p>Check current weather and 5-day forecasts with alerts.</p>
        <a href="/weather" class="btn">View Weather</a>
      </div>
      
      <div class="feature-card">
        <h3>📬 Contact Us</h3>
        <p>Get in touch with our team for any inquiries.</p>
        <a href="/contact" class="btn">Contact</a>
      </div>
    </section>
  </main>

  <footer class="footer">
    <p>&copy; <%= new Date().getFullYear() %> MTCM Portal. All rights reserved.</p>
  </footer>
</body>
</html>
