# Server
PORT=3000
NODE_ENV=development

# Redis (optional - uses memory store if not set)
REDIS_URL=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
OWNER_EMAIL=owner@example.com

# reCAPTCHA v3 (optional)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=

# Allowlist (comma-separated)
ALLOWLIST_IPS=
ALLOWLIST_EMAIL_DOMAINS=

# Force captcha for all (true/false)
FORCE_CAPTCHA_ALL=false

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5

# Admin credentials
ADMIN_USER=admin
ADMIN_PASS=admin123

# Session
SESSION_SECRET=your-secret-key-change-in-production
