<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - MTCM Portal</title>
  <link rel="stylesheet" href="/css/styles.css">
  <% if (showCaptcha && recaptchaSiteKey) { %>
  <script src="https://www.google.com/recaptcha/api.js" async defer></script>
  <% } %>
</head>
<body>
  <header class="header">
    <nav class="nav">
      <a href="/" class="nav-brand">MTCM Portal</a>
      <div class="nav-links">
        <a href="/lead">Lead Form</a>
        <a href="/contact" class="active">Contact Us</a>
      </div>
    </nav>
  </header>
  
  <main class="main">
    <div class="container">
      <h1>Contact Us</h1>
      <p>Have a question or need support? We're here to help.</p>
      
      <% if (errors && errors.length > 0) { %>
      <div class="alert alert-error">
        <ul>
          <% errors.forEach(function(error) { %>
          <li><%= error %></li>
          <% }); %>
        </ul>
      </div>
      <% } %>
      
      <form action="/contact" method="POST" class="form">
        <%- honeypotField %>
        
        <div class="form-group">
          <label for="name">Name *</label>
          <input type="text" id="name" name="name" required 
                 value="<%= formData.name || '' %>" 
                 placeholder="Your full name">
        </div>
        
        <div class="form-group">
          <label for="org">Organization</label>
          <input type="text" id="org" name="org" 
                 value="<%= formData.org || '' %>" 
                 placeholder="Company or organization name">
        </div>
        
        <div class="form-group">
          <label for="email">Email *</label>
          <input type="email" id="email" name="email" required 
                 value="<%= formData.email || '' %>" 
                 placeholder="your.email@example.com">
        </div>
        
        <div class="form-group">
          <label for="phone">Phone</label>
          <input type="tel" id="phone" name="phone" 
                 value="<%= formData.phone || '' %>" 
                 placeholder="(555) 123-4567">
        </div>
        
        <div class="form-group">
          <label for="notes">Message</label>
          <textarea id="notes" name="notes" rows="4" 
                    placeholder="How can we help you?"><%= formData.notes || '' %></textarea>
        </div>
        
        <% if (showCaptcha && recaptchaSiteKey) { %>
        <div class="form-group">
          <div class="g-recaptcha" data-sitekey="<%= recaptchaSiteKey %>"></div>
        </div>
        <% } %>
        
        <div class="form-group">
          <button type="submit" class="btn btn-primary">Send Message</button>
        </div>
      </form>
    </div>
  </main>
  
  <footer class="footer">
    <p>&copy; <%= new Date().getFullYear() %> MTCM Portal. All rights reserved.</p>
  </footer>
</body>
</html>
