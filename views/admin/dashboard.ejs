<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - MTCM Portal</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header class="header header-admin">
    <nav class="nav">
      <a href="/admin" class="nav-brand">MTCM Admin</a>
      <div class="nav-links">
        <a href="/admin">Dashboard</a>
        <a href="/admin/settings">Settings</a>
        <a href="/admin/logout">Logout</a>
      </div>
    </nav>
  </header>
  
  <main class="main">
    <div class="container">
      <h1>Admin Dashboard</h1>
      
      <div class="dashboard-cards">
        <div class="card">
          <h2>Settings</h2>
          <p>Manage allowlists and captcha settings</p>
          <a href="/admin/settings" class="btn btn-primary">Go to Settings</a>
        </div>
        
        <div class="card">
          <h2>Forms</h2>
          <p>View public forms</p>
          <div class="card-links">
            <a href="/lead" target="_blank" class="btn btn-secondary">Lead Form</a>
            <a href="/contact" target="_blank" class="btn btn-secondary">Contact Form</a>
          </div>
        </div>
      </div>
    </div>
  </main>
  
  <footer class="footer">
    <p>&copy; <%= new Date().getFullYear() %> MTCM Portal. All rights reserved.</p>
  </footer>
</body>
</html>
