<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | MTCM Portal</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-brand">
      <a href="/">MTCM Portal</a>
    </div>
    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/federal">Federal</a>
      <a href="/lead">Request Info</a>
      <a href="/contact">Contact</a>
      <a href="/weather">Weather</a>
      <a href="/admin" class="active">Admin</a>
      <a href="/signout">Sign Out</a>
    </div>
  </nav>

  <main class="container">
    <div class="admin-header">
      <h1>Admin Dashboard</h1>
      <div class="user-info">
        <% if (user.photo) { %>
          <img src="<%= user.photo %>" alt="Profile" class="user-avatar">
        <% } %>
        <span><%= user.name %> (<%= user.email %>)</span>
      </div>
    </div>

    <section class="admin-section">
      <h2>Site Configuration</h2>
      <form id="config-form" class="admin-form">
        <div class="form-group">
          <label for="siteName">Site Name</label>
          <input type="text" id="siteName" name="siteName" value="<%= config.siteName || '' %>">
        </div>
        
        <div class="form-group">
          <label for="weatherDefaultCity">Default Weather City</label>
          <input type="text" id="weatherDefaultCity" name="weatherDefaultCity" value="<%= config.weatherDefaultCity || '' %>">
        </div>
        
        <div class="form-group">
          <label for="weatherDefaultUnits">Weather Units</label>
          <select id="weatherDefaultUnits" name="weatherDefaultUnits">
            <option value="metric" <%= config.weatherDefaultUnits === 'metric' ? 'selected' : '' %>>Metric (°C)</option>
            <option value="imperial" <%= config.weatherDefaultUnits === 'imperial' ? 'selected' : '' %>>Imperial (°F)</option>
          </select>
        </div>
        
        <div class="form-group">
          <label for="weatherAlertPrecipMm">Weather Alert Threshold (mm)</label>
          <input type="number" id="weatherAlertPrecipMm" name="weatherAlertPrecipMm" value="<%= config.weatherAlertPrecipMm || 10 %>">
        </div>
        
        <div class="form-group">
          <label for="contactEmail">Contact Notification Email</label>
          <input type="email" id="contactEmail" name="contactEmail" value="<%= config.contactEmail || '' %>">
        </div>
        
        <div class="form-group">
          <label for="leadNotifyEmail">Lead Notification Email</label>
          <input type="email" id="leadNotifyEmail" name="leadNotifyEmail" value="<%= config.leadNotifyEmail || '' %>">
        </div>
        
        <button type="submit" class="btn btn-primary">Save Configuration</button>
        <span id="save-status"></span>
      </form>
    </section>

    <section class="admin-section">
      <h2>Quick Links</h2>
      <div class="admin-links">
        <a href="/api/admin/config" class="btn" target="_blank">View Config JSON</a>
        <a href="/healthz" class="btn" target="_blank">Health Check</a>
        <a href="/readyz" class="btn" target="_blank">Readiness Check</a>
      </div>
    </section>
  </main>

  <footer class="footer">
    <p>&copy; <%= new Date().getFullYear() %> MTCM Portal</p>
  </footer>

  <script>
    document.getElementById('config-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const status = document.getElementById('save-status');
      
      const data = {
        siteName: form.siteName.value,
        weatherDefaultCity: form.weatherDefaultCity.value,
        weatherDefaultUnits: form.weatherDefaultUnits.value,
        weatherAlertPrecipMm: parseInt(form.weatherAlertPrecipMm.value, 10),
        contactEmail: form.contactEmail.value,
        leadNotifyEmail: form.leadNotifyEmail.value
      };
      
      try {
        status.textContent = 'Saving...';
        const response = await fetch('/api/admin/config', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        
        if (response.ok) {
          status.textContent = '✓ Saved!';
          status.className = 'status-success';
        } else {
          const error = await response.json();
          status.textContent = '✗ ' + (error.error || 'Failed to save');
          status.className = 'status-error';
        }
      } catch (err) {
        status.textContent = '✗ Network error';
        status.className = 'status-error';
      }
      
      setTimeout(() => { status.textContent = ''; }, 3000);
    });
  </script>
</body>
</html>
