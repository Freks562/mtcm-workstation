<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - MTCM Portal</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header class="header header-admin">
    <nav class="nav">
      <a href="/admin" class="nav-brand">MTCM Admin</a>
      <div class="nav-links">
        <a href="/admin">Dashboard</a>
        <a href="/admin/settings" class="active">Settings</a>
        <a href="/admin/logout">Logout</a>
      </div>
    </nav>
  </header>
  
  <main class="main">
    <div class="container">
      <h1>Settings</h1>
      
      <% if (message) { %>
      <div class="alert alert-<%= message.type %>">
        <%= message.text %>
      </div>
      <% } %>
      
      <div class="settings-section">
        <h2>Form Protection Settings</h2>
        <form action="/admin/settings" method="POST" class="form">
          <div class="form-group">
            <label for="ALLOWLIST_IPS">Allowlist IPs</label>
            <textarea id="ALLOWLIST_IPS" name="ALLOWLIST_IPS" rows="3" 
                      placeholder="Comma-separated IP addresses (e.g., 192.168.1.1, 10.0.0.1)"><%= settings.ALLOWLIST_IPS || '' %></textarea>
            <small>IP addresses in this list will bypass rate limiting and captcha (unless Force Captcha is enabled).</small>
          </div>
          
          <div class="form-group">
            <label for="ALLOWLIST_EMAIL_DOMAINS">Allowlist Email Domains</label>
            <textarea id="ALLOWLIST_EMAIL_DOMAINS" name="ALLOWLIST_EMAIL_DOMAINS" rows="3" 
                      placeholder="Comma-separated domains (e.g., company.com, partner.org)"><%= settings.ALLOWLIST_EMAIL_DOMAINS || '' %></textarea>
            <small>Email domains in this list will bypass rate limiting and captcha (unless Force Captcha is enabled).</small>
          </div>
          
          <div class="form-group">
            <label class="checkbox-label">
              <input type="checkbox" name="FORCE_CAPTCHA_ALL" value="true" 
                     <%= settings.FORCE_CAPTCHA_ALL ? 'checked' : '' %>>
              Force Captcha for All
            </label>
            <small>When enabled, captcha is required for all submissions regardless of allowlist status.</small>
          </div>
          
          <div class="form-group">
            <button type="submit" class="btn btn-primary">Save Settings</button>
          </div>
        </form>
      </div>
      
      <div class="settings-section">
        <h2>Test Allowlist</h2>
        <p>Test if an IP address or email domain is in the allowlist.</p>
        
        <form action="/admin/settings/test-allowlist" method="POST" class="form">
          <div class="form-row">
            <div class="form-group">
              <label for="testIp">Test IP Address</label>
              <input type="text" id="testIp" name="testIp" 
                     placeholder="e.g., 192.168.1.1"
                     value="<%= testResult?.ip?.value || '' %>">
            </div>
            
            <div class="form-group">
              <label for="testEmail">Test Email</label>
              <input type="email" id="testEmail" name="testEmail" 
                     placeholder="e.g., user@example.com"
                     value="<%= testResult?.email?.value || '' %>">
            </div>
          </div>
          
          <div class="form-group">
            <button type="submit" class="btn btn-secondary">Test Allowlist</button>
          </div>
        </form>
        
        <% if (testResult) { %>
        <div class="test-results">
          <h3>Test Results</h3>
          
          <div class="result-item">
            <strong>IP:</strong> <%= testResult.ip.value || 'Not provided' %>
            <% if (testResult.ip.value) { %>
              <span class="badge <%= testResult.ip.allowed ? 'badge-success' : 'badge-warning' %>">
                <%= testResult.ip.allowed ? 'ALLOWED' : 'NOT IN ALLOWLIST' %>
              </span>
            <% } %>
          </div>
          
          <div class="result-item">
            <strong>Email:</strong> <%= testResult.email.value || 'Not provided' %>
            <% if (testResult.email.value) { %>
              <br>
              <strong>Domain:</strong> <%= testResult.email.domain %>
              <span class="badge <%= testResult.email.allowed ? 'badge-success' : 'badge-warning' %>">
                <%= testResult.email.allowed ? 'ALLOWED' : 'NOT IN ALLOWLIST' %>
              </span>
            <% } %>
          </div>
          
          <div class="result-item result-summary">
            <strong>Overall:</strong>
            <span class="badge badge-lg <%= testResult.isAllowed ? 'badge-success' : 'badge-error' %>">
              <%= testResult.isAllowed ? 'WOULD BYPASS PROTECTION' : 'WOULD BE SUBJECT TO RATE LIMITING' %>
            </span>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </main>
  
  <footer class="footer">
    <p>&copy; <%= new Date().getFullYear() %> MTCM Portal. All rights reserved.</p>
  </footer>
</body>
</html>
