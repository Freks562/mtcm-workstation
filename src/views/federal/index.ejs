<%- include('../layout', { body: `
  <section class="page-header federal-header">
    <div class="container">
      <div class="hero-badge">SDVOSB Certified</div>
      <h1>Federal Capabilities</h1>
      <p>Comprehensive IT solutions for federal agencies</p>
    </div>
  </section>

  <section class="capabilities">
    <div class="container">
      <h2 class="section-title">Our Capabilities</h2>
      
      <div class="capability-grid">
        ${federalKit.capabilities.map(cap => '<div class="capability-card"><h3>' + cap.name + '</h3><p>' + cap.description + '</p></div>').join('')}
      </div>
    </div>
  </section>

  <section class="certifications">
    <div class="container">
      <h2 class="section-title">Certifications</h2>
      
      <div class="cert-grid">
        ${federalKit.certifications.map(cert => '<div class="cert-card"><h3>' + cert.name + '</h3><p>' + cert.description + '</p></div>').join('')}
      </div>
    </div>
  </section>

  <section class="vehicles">
    <div class="container">
      <h2 class="section-title">Contract Vehicles</h2>
      
      <div class="vehicle-grid">
        ${contractVehicles.map(v => '<div class="vehicle-card"><div class="vehicle-status ' + v.status + '">' + v.status + '</div><h3>' + v.name + '</h3><p class="vehicle-fullname">' + v.fullName + '</p><p>' + v.description + '</p><div class="vehicle-categories">' + v.categories.map(c => '<span class="category-tag">' + c + '</span>').join('') + '</div></div>').join('')}
      </div>
    </div>
  </section>

  <section class="naics">
    <div class="container">
      <h2 class="section-title">NAICS Codes</h2>
      
      <div class="naics-grid">
        ${federalKit.naicsCodes.map(n => '<div class="naics-card"><span class="naics-code">' + n.code + '</span><span class="naics-desc">' + n.description + '</span></div>').join('')}
      </div>
    </div>
  </section>

  <section class="cta">
    <div class="container">
      <div class="cta-content">
        <h2>Request a Quote</h2>
        <p>Contact our federal sales team to discuss your requirements</p>
        <a href="/contact" class="btn btn-light btn-lg">Contact Sales</a>
      </div>
    </div>
  </section>
`}) %>
